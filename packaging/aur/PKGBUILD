pkgname=bootcontrol
pkgver=0.1.0
pkgrel=1
pkgdesc="A modern, memory-safe bootloader manager for Linux - built in Rust."
url="https://github.com/szymonpaczos/bootcontrol"
arch=('x86_64')
license=('GPL3')
depends=('dbus' 'polkit')
makedepends=('rust' 'cargo' 'dbus')
source=("git+https://github.com/szymonpaczos/bootcontrol.git#tag=v${pkgver}")
md5sums=('SKIP')

build() {
  cd "${pkgname}"
  cargo build --release --workspace
}

package() {
  cd "${pkgname}"

  # Binaries
  install -Dm755 target/release/bootcontrol "${pkgdir}/usr/bin/bootcontrol"
  install -Dm755 target/release/bootcontrold "${pkgdir}/usr/bin/bootcontrold"

  # Polkit policy
  install -Dm644 packaging/polkit/org.bootcontrol.policy "${pkgdir}/usr/share/polkit-1/actions/org.bootcontrol.policy"

  # D-Bus policy
  install -Dm644 packaging/dbus/org.bootcontrol.Manager.conf "${pkgdir}/usr/share/dbus-1/system.d/org.bootcontrol.Manager.conf"

  # Systemd units
  install -Dm644 packaging/systemd/bootcontrold.service "${pkgdir}/usr/lib/systemd/system/bootcontrold.service"
  install -Dm644 packaging/systemd/bootcontrold.socket "${pkgdir}/usr/lib/systemd/system/bootcontrold.socket"
}
