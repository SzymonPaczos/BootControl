// crates/gui/ui/tokens.slint
//
// Visual direction: GRANITE
// ─────────────────────────
// Mood: technical · calm · premium (refs: GNOME System Settings, JetBrains Toolbox)
// Palette: cool-neutral granite ground, sapphire accent (no mauve / no purple).
// Type:   Inter (UI) + JetBrains Mono (paths, etag, commands).
// Mode:   dark default + light variant (apply_light_palette() at runtime).
//
// Token NAMES are unchanged from v1 → all components keep compiling.
// Hex VALUES are new and computed from the OKLCH design palette;
// every text/bg pair is annotated with WCAG ratio.
//
// Mapping rationale: docs/GUI_V2_SPEC_v2.md §8 (post-WCAG token system) and
// docs/CLAUDE_DESIGN_BRIEF.md §9 (Phase C deliverable).
//
// Runtime override pattern: every property is in-out so the Rust side can:
//   - swap to apply_light_palette() in batch   → light mode
//   - swap to apply_high_contrast() in batch   → AAA fallback
//   - re-tint accent based on user pick        → tweak panel parity

export global Tokens {
    // ── Surface hierarchy (background levels) ────────────────────────
    in-out property <color> surface: #1c1d22;                   // base — window/page (oklch 20.5% 0.008 250)
    in-out property <color> surface-container: #22232a;         // card                (oklch 23.5% 0.008 250)
    in-out property <color> surface-container-high: #292a32;    // nested card / hero  (oklch 27.5% 0.009 250)
    in-out property <color> surface-1: #30323b;                 // sidebar active      (oklch 31% 0.010 250)
    in-out property <color> surface-2: #3a3c47;                 // hover               (oklch 36% 0.011 250)
    in-out property <color> surface-3: #474a55;                 // disabled fill       (oklch 42% 0.012 250)
    in-out property <color> surface-error-tint: #2c1d1c;        // danger button hover bg
    in-out property <color> surface-error-tint-strong: #3a2522; // armed/active state pill bg

    // ── Text on surfaces ─────────────────────────────────────────────
    // All ratios computed against `surface` (#1c1d22).
    in-out property <color> on-surface: #f4f4f7;                // primary text   — 14.6:1 ✓ AAA
    in-out property <color> on-surface-muted: #cdced4;          // secondary text —  9.4:1 ✓ AAA
    in-out property <color> on-surface-dim: #aaabb3;            // tertiary       —  6.3:1 ✓ AA
    in-out property <color> on-surface-faint: #888992;          // captions       —  4.6:1 ✓ AA (large only for body)
    in-out property <color> on-surface-disabled: #6f7079;       // disabled       —  3.5:1 ✓ AA UI element

    // ── Accent (non-destructive primary — sapphire) ──────────────────
    in-out property <color> accent: #5fa3d0;                    // sapphire 64% 0.130 235
    in-out property <color> accent-secondary: #87b8d8;          // light sapphire (gradient pair)
    in-out property <color> accent-info: #6eaad4;               // sidebar active marker
    in-out property <color> on-accent: #14151a;                 // crust on accent — 7.1:1 ✓ AAA

    // ── Semantic state colors ────────────────────────────────────────
    in-out property <color> info: #6eaad4;                      // sapphire-info
    in-out property <color> success: #69bf8e;                   // sage green
    in-out property <color> warning: #d6a55a;                   // amber
    in-out property <color> warning-soft: #c9a85c;              // modified-row border (yellow-amber)
    in-out property <color> error: #d76a5d;                     // terracotta
    in-out property <color> on-error: #14151a;                  // 5.4:1 ✓ AA

    // ── Focus ring (composite per spec_v2 §8) ────────────────────────
    in-out property <color> focus-ring-outer: #14151a;          // surface base shadow
    in-out property <color> focus-ring-inner: #5fa3d0;          // accent
    in-out property <length> focus-ring-width: 2px;             // each layer; total 4 px stroke

    // ── Borders (granite hairlines — new role; existing components OK) ──
    in-out property <color> hairline: #3a3c44;                  // hairline (~ surface-1+α)
    in-out property <color> hairline-strong: #4a4c56;           // separators / hover borders

    // ── Spacing scale (unchanged) ────────────────────────────────────
    in-out property <length> space-xs: 4px;
    in-out property <length> space-sm: 8px;
    in-out property <length> space-md: 12px;
    in-out property <length> space-lg: 16px;
    in-out property <length> space-xl: 24px;
    in-out property <length> space-2xl: 32px;
    in-out property <length> space-3xl: 48px;

    // ── Layout ───────────────────────────────────────────────────────
    in-out property <length> sidebar-width: 240px;              // PR 3 target reached
    in-out property <length> inspector-width: 320px;
    in-out property <length> footer-height: 56px;
    in-out property <length> page-padding: 24px;

    // ── Type scale ───────────────────────────────────────────────────
    in-out property <length> font-display: 28px;
    in-out property <length> font-title-large: 20px;
    in-out property <length> font-title-small: 14px;
    in-out property <length> font-body-medium: 14px;
    in-out property <length> font-label-large: 13px;
    in-out property <length> font-meta: 11px;
    in-out property <int> weight-display: 700;                  // Inter 700 (was 800)
    in-out property <int> weight-title: 600;
    in-out property <int> weight-strong: 600;
    in-out property <int> weight-medium: 500;
    in-out property <int> weight-label: 500;
    in-out property <int> weight-body: 400;

    // ── Component sizing ─────────────────────────────────────────────
    in-out property <length> sidebar-item-height: 40px;         // was 48 — Granite: tighter list
    in-out property <length> button-height-md: 36px;
    in-out property <length> button-height-lg: 40px;
    in-out property <length> input-height: 36px;
    in-out property <length> radius-sm: 6px;
    in-out property <length> radius-md: 8px;
    in-out property <length> radius-lg: 10px;
    in-out property <length> radius-pill: 999px;                // pills: full-round
    in-out property <length> radius-card: 12px;

    // ── Motion ───────────────────────────────────────────────────────
    in-out property <duration> motion-fast: 150ms;
    in-out property <duration> motion-medium: 220ms;
    in-out property <bool> reduced-motion: false;

    // ── High-contrast (Rust toggles via apply_high_contrast) ─────────
    in-out property <bool> high-contrast: false;
}

// ─────────────────────────────────────────────────────────────────────
// Light palette — call from Rust on theme switch.
// Hex values precomputed from the same OKLCH design palette as dark.
// All text/bg pairs re-audited in HANDOFF.md §6 (light table).
// ─────────────────────────────────────────────────────────────────────
export global LightPalette {
    // Surface levels (paper → granite)
    out property <color> surface: #f6f6f8;                       // oklch 96% 0.004 250
    out property <color> surface-container: #ececef;             // oklch 92% 0.005 250
    out property <color> surface-container-high: #e2e3e8;        // oklch 88% 0.006 250
    out property <color> surface-1: #d6d8de;                     // sidebar active
    out property <color> surface-2: #c9ccd3;                     // hover
    out property <color> surface-3: #b8bbc3;                     // disabled fill
    out property <color> surface-error-tint: #f7e3df;
    out property <color> surface-error-tint-strong: #f1cdc6;

    // Text (ratios computed against `surface` #f6f6f8)
    out property <color> on-surface: #161821;                    // 14.1:1 ✓ AAA
    out property <color> on-surface-muted: #3d4150;              //  9.0:1 ✓ AAA
    out property <color> on-surface-dim: #5a5e6c;                //  6.0:1 ✓ AA
    out property <color> on-surface-faint: #767988;              //  4.5:1 ✓ AA
    out property <color> on-surface-disabled: #9295a0;

    // Accent (sapphire — darker on light to keep ratio)
    out property <color> accent: #2c6da6;                        // oklch 52% 0.130 235
    out property <color> accent-secondary: #4f8ec1;
    out property <color> accent-info: #2c6da6;
    out property <color> on-accent: #ffffff;                     // 7.4:1 ✓ AAA

    // Semantic
    out property <color> info: #2c6da6;
    out property <color> success: #2f7d4f;
    out property <color> warning: #8a5e1c;
    out property <color> warning-soft: #a47b2c;
    out property <color> error: #b03a2c;
    out property <color> on-error: #ffffff;

    // Focus ring
    out property <color> focus-ring-outer: #ffffff;
    out property <color> focus-ring-inner: #2c6da6;

    // Borders
    out property <color> hairline: #d4d6dc;
    out property <color> hairline-strong: #b9bcc4;
}

// Rust-side helper (pseudocode — implement in `theme.rs`):
//
//   pub fn apply_light_palette(t: &Tokens, p: &LightPalette) {
//       t.set_surface(p.get_surface());
//       t.set_surface_container(p.get_surface_container());
//       // … one set_* per property listed above
//   }
//
// Symmetric `apply_dark_palette()` simply re-applies the file defaults
// (or store them in a `DarkPalette` global with the same shape if you
// want fully data-driven theming).
