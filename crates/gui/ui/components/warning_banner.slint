// crates/gui/ui/components/warning_banner.slint
//
// Static warning banner used at the top of dangerous pages (Security Lab,
// Strict Mode disclosure). Granite restyle: surface-container ground +
// 3 px left error stripe + colorized warning SVG (matches info_bar pattern).
// HANDOFF.md §4 (info_bar) — warning_banner inherits the same treatment.

import { Tokens } from "../tokens.slint";

export component WarningBanner inherits Rectangle {
    in property <string> message;

    accessible-role: text;
    accessible-label: "Warning";
    accessible-description: root.message;

    border-radius: Tokens.radius-md;
    background: Tokens.surface-container;
    border-width: 1px;
    border-color: Tokens.hairline;
    clip: true;

    Rectangle {
        x: 0;
        y: 0;
        width: 3px;
        height: parent.height;
        background: Tokens.error;
    }

    HorizontalLayout {
        padding-top: 14px;
        padding-bottom: 14px;
        padding-left: Tokens.space-lg;
        padding-right: Tokens.space-lg;
        spacing: Tokens.space-md;
        alignment: start;

        Image {
            source: @image-url("../../assets/icons/warning.svg");
            width: 18px;
            height: 18px;
            colorize: Tokens.error;
            y: 1px;
        }

        Text {
            text: root.message;
            color: Tokens.on-surface;
            font-size: Tokens.font-label-large;
            font-weight: Tokens.weight-medium;
            vertical-alignment: center;
            wrap: word-wrap;
            horizontal-stretch: 1;
        }
    }
}
