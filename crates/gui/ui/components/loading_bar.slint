// crates/gui/ui/components/loading_bar.slint
//
// In-page progress indicator. Collapses to height 0 when inactive.
// Used as a generic "something is happening" surface above page content.
// PR 4 will add the Live Job Log component for long-running ops with output.

import { Tokens } from "../tokens.slint";

export component LoadingBar inherits Rectangle {
    in property <bool> active: false;
    in property <string> message: "Processing...";

    accessible-role: progress-indicator;
    accessible-label: "Loading";
    accessible-description: root.message;

    height: root.active ? 44px : 0px;
    border-radius: Tokens.radius-md;
    background: Tokens.surface-1;
    clip: true;

    animate height { duration: Tokens.reduced-motion ? 0ms : 180ms; easing: ease-in-out; }

    // Granite: a thin sapphire bar along the top edge marks active state.
    // A true indeterminate sweep needs a Timer-driven property — deferred
    // to a follow-up; Granite v1 ships the static accent line.
    Rectangle {
        x: 0;
        y: 0;
        width: parent.width;
        height: 2px;
        background: @linear-gradient(90deg,
            #ffffff00 0%,
            Tokens.accent 30%,
            Tokens.accent-secondary 70%,
            #ffffff00 100%);
    }

    HorizontalLayout {
        padding-left: Tokens.space-lg;
        padding-right: Tokens.space-lg;
        spacing: Tokens.space-md;
        alignment: start;

        Text {
            text: root.message;
            color: Tokens.on-surface-muted;
            font-size: Tokens.font-label-large;
            font-weight: Tokens.weight-medium;
            vertical-alignment: center;
        }
    }
}
