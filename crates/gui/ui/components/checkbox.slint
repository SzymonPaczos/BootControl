// crates/gui/ui/components/checkbox.slint
//
// Two-state checkbox with label. accent-info fill when checked.

import { Tokens } from "../tokens.slint";

export component CheckBox inherits Rectangle {
    in-out property <bool> checked: false;
    in property <string> label;

    height: 28px;

    accessible-role: checkbox;
    accessible-label: root.label;
    accessible-checked: root.checked;

    HorizontalLayout {
        spacing: Tokens.space-sm;
        alignment: start;

        Rectangle {
            width: 20px;
            height: 20px;
            border-radius: 4px;
            border-width: 2px;
            border-color: root.checked ? Tokens.accent-info : Tokens.surface-2;
            background: root.checked ? Tokens.accent-info : transparent;

            animate background, border-color { duration: Tokens.motion-fast; }

            if root.checked : Text {
                text: "✓";
                color: Tokens.on-accent;
                font-size: 12px;
                font-weight: Tokens.weight-strong;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
        }

        Text {
            text: root.label;
            color: Tokens.on-surface;
            font-size: Tokens.font-body-medium;
            vertical-alignment: center;
        }
    }

    TouchArea {
        clicked => { root.checked = !root.checked; }
    }
}
