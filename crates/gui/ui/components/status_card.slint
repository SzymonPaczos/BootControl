// crates/gui/ui/components/status_card.slint
//
// Status indicator card. Granite restyle (HANDOFF.md §4):
//   - Border becomes the neutral `hairline` token (no longer state-coloured)
//   - Status surfaces as an 8 px dot in the top-right corner with a
//     12 × 12 transparent ring (Slint substitute for the box-shadow halo)
//   - Value text colour still tracks status for emphasis

import { Tokens } from "../tokens.slint";

export component StatusCard inherits Rectangle {
    in property <string> label;
    in property <string> value;
    in property <string> status: "neutral";

    property <color> dot-color: root.status == "good" ? Tokens.success
        : (root.status == "bad" ? Tokens.error
        : (root.status == "info" ? Tokens.accent-info
        : Tokens.on-surface-faint));

    accessible-role: text;
    accessible-label: root.label;
    accessible-description: root.label + ": " + root.value
        + (root.status == "good" ? " (good)"
        : (root.status == "bad" ? " (problem)"
        : (root.status == "info" ? " (info)" : "")));

    horizontal-stretch: 1;
    height: 84px;
    border-radius: Tokens.radius-lg;
    background: Tokens.surface-container;
    border-width: 1px;
    border-color: Tokens.hairline;

    VerticalLayout {
        padding: Tokens.space-lg;
        spacing: Tokens.space-xs;
        alignment: start;

        Text {
            text: root.label;
            color: Tokens.on-surface-faint;
            font-size: Tokens.font-meta;
            font-weight: Tokens.weight-strong;
        }

        Text {
            text: root.value;
            color: root.status == "good" ? Tokens.success
                : (root.status == "bad" ? Tokens.error
                : (root.status == "info" ? Tokens.accent-info
                : Tokens.on-surface));
            font-size: 15px;
            font-weight: Tokens.weight-strong;
        }
    }

    // Halo ring (12 × 12 transparent + colour-tinted at 24% alpha)
    Rectangle {
        x: parent.width - self.width - Tokens.space-md;
        y: Tokens.space-md;
        width: 12px;
        height: 12px;
        border-radius: 6px;
        background: root.dot-color;
        opacity: 0.22;
    }

    // Solid dot
    Rectangle {
        x: parent.width - self.width - Tokens.space-md - 2px;
        y: Tokens.space-md + 2px;
        width: 8px;
        height: 8px;
        border-radius: 4px;
        background: root.dot-color;
    }
}
