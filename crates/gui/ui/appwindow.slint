import { ScrollView } from "std-widgets.slint";

export struct GrubEntry {
    key: string,
    value: string,
    original_value: string,
    is_modified: bool,
}

component SidebarItem inherits Rectangle {
    in property <string> text;
    in property <bool> active: false;
    callback clicked <=> touch.clicked;

    height: 48px;
    border-radius: 8px;
    background: root.active ? #313244 : (touch.has-hover ? #1e1e2e : transparent);
    
    animate background { duration: 150ms; }

    HorizontalLayout {
        padding-left: 12px;
        spacing: 12px;
        alignment: start;
        
        // Icon placeholder
        Rectangle {
            width: 4px;
            height: 20px;
            background: root.active ? #89b4fa : transparent;
            border-radius: 2px;
        }

        Text {
            text: root.text;
            color: root.active ? #89b4fa : #a6adc8;
            font-size: 14px;
            font-weight: root.active ? 700 : 500;
            vertical-alignment: center;
        }
    }
    touch := TouchArea {}
}

component GhostButton inherits Rectangle {
    in-out property <string> text;
    callback clicked <=> touch.clicked;

    height: 36px;
    border-radius: 8px;
    background: touch.pressed ? #313244 : (touch.has-hover ? #45475a : transparent);
    
    animate background { duration: 150ms; }

    Text {
        text: root.text;
        color: #cdd6f4;
        font-size: 14px;
        font-weight: 600;
        horizontal-alignment: center;
        vertical-alignment: center;
    }
    touch := TouchArea {}
}

component PrimaryButton inherits Rectangle {
    in-out property <string> text;
    callback clicked <=> touch.clicked;
    in property <bool> enabled: true;

    height: 36px;
    border-radius: 8px;
    background: root.enabled ? (touch.pressed ? @linear-gradient(90deg, #cba6f7 0%, #b4befe 100%) : @linear-gradient(90deg, #b4befe 0%, #cba6f7 100%)) : #45475a;
    
    animate background { duration: 150ms; }

    Text {
        text: root.text;
        color: root.enabled ? #11111b : #a6adc8;
        font-size: 14px;
        font-weight: 700;
        horizontal-alignment: center;
        vertical-alignment: center;
    }
    touch := TouchArea {
        enabled: root.enabled;
    }
}

component StyledInput inherits Rectangle {
    in-out property <string> text <=> input.text;
    callback edited(string);
    
    height: 36px;
    border-radius: 6px;
    background: #11111b;
    border-width: 1px;
    border-color: input.has-focus ? #b4befe : #313244;
    
    animate border-color { duration: 150ms; }

    HorizontalLayout {
        padding-left: 12px;
        padding-right: 12px;
        input := TextInput {
            horizontal-alignment: left;
            vertical-alignment: center;
            color: #cdd6f4;
            font-size: 14px;
            single-line: true;
            edited => { root.edited(self.text); }
        }
    }
}

component ToastNotification inherits Rectangle {
    in property <string> message;
    in property <string> toast_type: "error";
    in property <bool> is_visible: false;
    callback dismiss;

    width: 400px;
    height: 50px;
    border-radius: 10px;
    background: root.toast_type == "error" ? #f38ba8 : (root.toast_type == "success" ? #a6e3a1 : #89b4fa);
    opacity: root.is_visible ? 1.0 : 0.0;
    
    animate opacity { duration: 200ms; }

    HorizontalLayout {
        padding: 12px;
        spacing: 12px;
        Text {
            text: root.message;
            color: #11111b;
            font-size: 13px;
            font-weight: 700;
            vertical-alignment: center;
            horizontal-stretch: 1;
        }
        GhostButton {
            text: "✕";
            width: 24px;
            clicked => { root.dismiss(); }
        }
    }
}

export component AppWindow inherits Window {
    title: "BootControl";
    width: 1000px;
    height: 750px;
    background: #181825;
    default-font-family: "Inter, Roboto, sans-serif";
    
    in-out property <[GrubEntry]> entries: [];
    in property <string> toast_message: "";
    in property <string> toast_type: "info";
    in property <bool> show_toast: false;
    in property <string> active_backend: "grub";
    in-out property <int> active_tab: 0;
    
    callback fetch_entries();
    callback save_entry(string, string);
    callback dismiss_toast();

    HorizontalLayout {
        // Sidebar
        Rectangle {
            width: 220px;
            background: #11111b;
            
            VerticalLayout {
                padding: 24px;
                spacing: 8px;
                alignment: start;
                
                Text {
                    text: "BootControl";
                    font-size: 20px;
                    font-weight: 800;
                    color: #cdd6f4;
                    padding-bottom: 24px;
                }
                
                SidebarItem { 
                    text: "Boot Settings"; 
                    active: root.active_tab == 0;
                    clicked => { root.active_tab = 0; }
                }
                SidebarItem { 
                    text: "Secure Boot"; 
                    active: root.active_tab == 1;
                    clicked => { root.active_tab = 1; }
                }
                SidebarItem { 
                    text: "Security Lab"; 
                    active: root.active_tab == 2;
                    clicked => { root.active_tab = 2; }
                }
                
                Rectangle { vertical-stretch: 1; } // spacer
                
                Text {
                    text: "v1.0.0-alpha";
                    color: #45475a;
                    font-size: 11px;
                }
            }
        }
        
        // Main Content
        Rectangle {
            background: #1e1e2e;
            
            VerticalLayout {
                padding: 32px;
                spacing: 24px;
                
                // Content Header
                HorizontalLayout {
                    alignment: space-between;
                    VerticalLayout {
                        spacing: 4px;
                        Text {
                            text: root.active_tab == 0 ? "Configuration" : (root.active_tab == 1 ? "Secure Boot" : "Security Lab");
                            font-size: 28px;
                            font-weight: 700;
                            color: #cdd6f4;
                        }
                        Text {
                            text: "Backend: " + root.active_backend;
                            font-size: 13px;
                            color: #6c7086;
                        }
                    }
                    if root.active_tab == 0 : GhostButton {
                        text: "↻ Refresh";
                        width: 100px;
                        clicked => { root.fetch_entries(); }
                    }
                }
                
                // Tab Views
                if root.active_tab == 0 : Rectangle {
                    background: #181825;
                    border-radius: 12px;
                    ScrollView {
                        padding: 16px;
                        VerticalLayout {
                            spacing: 8px;
                            for entry[i] in root.entries : Rectangle {
                                height: 60px;
                                background: #1e1e2e;
                                border-radius: 8px;
                                border-width: 1px;
                                border-color: entry.is_modified ? #f9e2af : #313244;
                                
                                animate border-color { duration: 150ms; }

                                HorizontalLayout {
                                    padding-left: 16px;
                                    padding-right: 16px;
                                    spacing: 12px;
                                    alignment: center;
                                    
                                    Text {
                                        width: 180px;
                                        text: entry.key;
                                        color: #89b4fa;
                                        font-size: 14px;
                                        font-weight: 600;
                                        vertical-alignment: center;
                                    }
                                    
                                    StyledInput {
                                        horizontal-stretch: 1;
                                        text: entry.value;
                                        edited(tx) => { 
                                            root.entries[i].value = tx;
                                            root.entries[i].is_modified = (tx != root.entries[i].original_value);
                                        }
                                    }
                                    
                                    PrimaryButton {
                                        text: "Save";
                                        width: 80px;
                                        enabled: entry.is_modified;
                                        clicked => {
                                            root.save_entry(entry.key, entry.value);
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
                
                if root.active_tab == 1 : Rectangle {
                    background: #181825;
                    border-radius: 12px;
                    VerticalLayout {
                        padding: 40px;
                        spacing: 20px;
                        alignment: start;
                        Text {
                            text: "Secure Boot Management";
                            color: #cdd6f4;
                            font-size: 18px;
                            font-weight: 600;
                        }
                        Text {
                            text: "Manage MOK certificates and UKI signing settings.";
                            color: #6c7086;
                            font-size: 14px;
                        }
                        
                        HorizontalLayout {
                            spacing: 12px;
                            PrimaryButton { text: "Backup NVRAM"; width: 150px; }
                            PrimaryButton { text: "Enroll MOK"; width: 150px; }
                        }
                    }
                }

                if root.active_tab == 2 : Rectangle {
                    background: #181825;
                    border-radius: 12px;
                    VerticalLayout {
                        padding: 40px;
                        spacing: 20px;
                        alignment: start;
                        Text {
                            text: "Paranoia Mode (Experimental)";
                            color: #f38ba8;
                            font-size: 18px;
                            font-weight: 600;
                        }
                        Text {
                            text: "Take full ownership of EFI variables. Dangerous operations.";
                            color: #6c7086;
                            font-size: 14px;
                        }
                        PrimaryButton { text: "Generate Custom PK/KEK"; width: 200px; }
                    }
                }
            }
        }
    }

    ToastNotification {
        x: (parent.width - self.width) / 2;
        y: root.show_toast ? parent.height - self.height - 20px : parent.height + 10px;
        message: root.toast_message;
        toast_type: root.toast_type;
        is_visible: root.show_toast;
        dismiss => { root.dismiss_toast(); }
    }
}
