// crates/gui/ui/appwindow.slint
//
// Top-level AppWindow router. PR 6 expands routing from 3 to 7 pages
// (Overview / Boot Entries / Bootloader / Secure Boot / Snapshots / Logs /
// Settings) per docs/GUI_V2_SPEC_v2.md §3 IA.
//
// Off-sidebar route: active_tab == 7 → SecurityLabPage (legacy Strict Mode
// content). PR 7 surfaces this as a Strict Mode disclosure on Secure Boot
// per Q4 verdict; PR 6 leaves the file in pages/ as the source of truth.

import { Tokens } from "tokens.slint";
import { GrubEntry, DiffLine, PreflightCheck } from "types.slint";
import { GhostButton } from "components/ghost_button.slint";
import { Sidebar } from "components/sidebar.slint";
import { LoadingBar } from "components/loading_bar.slint";
import { ConfirmationSheet } from "components/confirmation_sheet.slint";
import { RecoveryViewer } from "components/recovery_viewer.slint";
import { OverviewPage } from "pages/overview.slint";
import { BootEntriesPage } from "pages/boot_entries.slint";
import { BootloaderPage } from "pages/bootloader.slint";
import { SecureBootPage } from "pages/secure_boot.slint";
import { SnapshotsPage, SnapshotRow } from "pages/snapshots.slint";
import { LogsPage, LogRow } from "pages/logs.slint";
import { SettingsPage } from "pages/settings.slint";
import { SecurityLabPage } from "pages/security_lab.slint";

// Re-export structs and globals so Rust generated bindings expose them.
export { GrubEntry, DiffLine, PreflightCheck, SnapshotRow, LogRow }
export { Tokens }

// ─── Toast notification (top-level overlay — kept inline) ───────────────────
//
// Granite restyle (HANDOFF.md §4): bg is `surface-container-high`, role
// colour appears as a 4 px left strip — toast reads as a notification,
// not a banner.

component ToastNotification inherits Rectangle {
    in property <string> message;
    in property <string> toast_type: "error";
    in property <bool> is_visible: false;
    callback dismiss;

    property <color> strip-color: root.toast_type == "error"
        ? Tokens.error
        : (root.toast_type == "success" ? Tokens.success : Tokens.accent-info);

    width: 420px;
    height: 52px;
    border-radius: Tokens.radius-lg;
    background: Tokens.surface-container-high;
    border-width: 1px;
    border-color: Tokens.hairline;
    opacity: root.is_visible ? 1.0 : 0.0;
    clip: true;

    animate opacity { duration: Tokens.motion-medium; }

    // 4 px left role strip
    Rectangle {
        x: 0;
        y: 0;
        width: 4px;
        height: parent.height;
        background: root.strip-color;
    }

    HorizontalLayout {
        padding-left: Tokens.space-lg;
        padding-right: Tokens.space-md;
        padding-top: 14px;
        padding-bottom: 14px;
        spacing: Tokens.space-md;
        Text {
            text: root.message;
            color: Tokens.on-surface;
            font-size: Tokens.font-label-large;
            font-weight: Tokens.weight-medium;
            vertical-alignment: center;
            horizontal-stretch: 1;
            overflow: elide;
        }
        Rectangle {
            width: 24px;
            height: 24px;
            border-radius: Tokens.radius-sm;
            background: close-touch.has-hover ? Tokens.surface-1 : transparent;
            accessible-role: button;
            accessible-label: "Dismiss notification";
            Image {
                source: @image-url("../assets/icons/close.svg");
                width: 12px;
                height: 12px;
                colorize: Tokens.on-surface-faint;
                x: (parent.width - self.width) / 2;
                y: (parent.height - self.height) / 2;
            }
            close-touch := TouchArea {
                clicked => { root.dismiss(); }
            }
        }
    }
}

// ─── Main window ─────────────────────────────────────────────────────────────

export component AppWindow inherits Window {
    title: "BootControl";
    width: 1100px;
    height: 780px;
    background: Tokens.surface-container;
    default-font-family: "Inter, Roboto, sans-serif";

    // ── Existing state ───────────────────────────────────────────────────────
    in-out property <[GrubEntry]> entries: [];
    in property <string> toast_message: "";
    in property <string> toast_type: "info";
    in property <bool> show_toast: false;
    in property <string> active_backend: "grub";
    in-out property <int> active_tab: 0;
    in property <bool> show_loading: false;
    in property <string> loading_message: "Processing...";
    in property <string> secure_boot_status: "Unknown";
    in property <string> mok_status: "Unknown";
    in-out property <bool> paranoia_confirmed: false;

    // ── Confirmation Sheet state (PR 4) ──────────────────────────────────────
    in-out property <bool> show_confirmation: false;
    in property <string> confirmation_verb: "";
    in property <string> confirmation_target: "";
    in property <string> confirmation_required_text: "";
    in-out property <string> confirmation_typed_text: "";
    in property <[DiffLine]> confirmation_diff: [];
    in property <[PreflightCheck]> confirmation_preflight: [];
    in property <bool> confirmation_preflight_all_pass: false;
    in property <string> confirmation_command_cli: "";
    in property <string> confirmation_snapshot_id: "";

    // ── Overview page state (PR 6) ───────────────────────────────────────────
    in property <string> overview_default_entry: "—";
    in property <int> overview_grub_timeout: 0;
    in property <string> overview_grub_path: "—";
    in property <string> overview_grub_etag: "—";
    in property <bool> overview_setup_mode: false;
    in property <int> overview_mok_count: 0;
    in property <int> overview_snapshot_count: 0;
    in property <string> overview_last_snapshot: "—";
    in-out property <bool> show_onboarding: false;

    // ── Snapshots page state ─────────────────────────────────────────────────
    in property <[SnapshotRow]> snapshot_rows: [];
    in property <bool> snapshots_disk_pressure: false;
    in property <string> snapshots_disk_usage: "";

    // ── Logs page state ──────────────────────────────────────────────────────
    in property <[LogRow]> log_rows: [];
    in-out property <bool> logs_only_failures: false;
    in-out property <bool> logs_only_mine: false;
    in-out property <string> logs_time_window: "all";

    // ── Settings page state ──────────────────────────────────────────────────
    in-out property <string> settings_retention_preset: "default";
    in-out property <bool> settings_auto_dismiss: false;
    in-out property <string> settings_high_contrast: "auto";
    in-out property <string> settings_reduced_motion: "auto";
    in property <bool> settings_strict_mode_allowed: false;

    // ── RecoveryViewer overlay state ─────────────────────────────────────────
    in-out property <bool> show_recovery_viewer: false;
    in property <string> recovery_markdown: "";

    // ── Existing callbacks ───────────────────────────────────────────────────
    callback fetch_entries();
    callback save_entry(string, string);
    callback dismiss_toast();
    callback rebuild_grub();
    callback backup_nvram();
    callback enroll_mok();
    callback generate_paranoia();
    callback merge_paranoia();

    // ── Confirmation Sheet callbacks ─────────────────────────────────────────
    callback open_confirmation(string);
    callback confirmation_confirmed();
    callback copy_command(string);

    // ── Onboarding + new page callbacks (PR 6) ───────────────────────────────
    callback never_show_onboarding();
    callback learn_more();
    callback restore_snapshot(string);
    callback open_recovery_viewer();
    callback open_audit_log(string);
    callback toggle_logs_filter(string);
    callback copy_log_row(string);
    callback save_logs_as();

    HorizontalLayout {
        // ── Sidebar ──────────────────────────────────────────────────────────
        Sidebar {
            active-tab <=> root.active_tab;
        }

        // ── Main content area ────────────────────────────────────────────────
        Rectangle {
            background: Tokens.surface;

            VerticalLayout {
                padding: Tokens.space-2xl;
                spacing: Tokens.space-lg;

                // ── Page header ──────────────────────────────────────────────
                HorizontalLayout {
                    alignment: space-between;

                    VerticalLayout {
                        spacing: Tokens.space-xs;
                        Text {
                            text: root.active_tab == 0 ? "Overview"
                                : (root.active_tab == 1 ? "Boot Entries"
                                : (root.active_tab == 2 ? "Bootloader"
                                : (root.active_tab == 3 ? "Secure Boot"
                                : (root.active_tab == 4 ? "Snapshots"
                                : (root.active_tab == 5 ? "Logs"
                                : (root.active_tab == 6 ? "Settings"
                                : "Strict Mode"))))));
                            font-size: 26px;
                            font-weight: Tokens.weight-strong;
                            color: Tokens.on-surface;
                        }
                        Text {
                            text: "Backend: " + root.active_backend;
                            font-size: Tokens.font-label-large;
                            color: Tokens.on-surface-faint;
                        }
                    }

                    if root.active_tab == 1 : HorizontalLayout {
                        spacing: Tokens.space-sm;
                        alignment: end;

                        GhostButton {
                            text: "Refresh";
                            width: 110px;
                            enabled: !root.show_loading;
                            clicked => { root.fetch_entries(); }
                        }
                        GhostButton {
                            text: "Rebuild GRUB";
                            width: 158px;
                            enabled: !root.show_loading;
                            clicked => {
                                root.confirmation_typed_text = "";
                                root.open_confirmation("rewrite-grub");
                            }
                        }
                    }
                }

                LoadingBar {
                    active: root.show_loading;
                    message: root.loading_message;
                }

                // ── Page router ──────────────────────────────────────────────
                if root.active_tab == 0 : OverviewPage {
                    active-backend: root.active_backend;
                    grub-default-entry: root.overview_default_entry;
                    grub-timeout: root.overview_grub_timeout;
                    grub-config-path: root.overview_grub_path;
                    grub-config-etag: root.overview_grub_etag;
                    secure-boot-status: root.secure_boot_status;
                    setup-mode-active: root.overview_setup_mode;
                    mok-count: root.overview_mok_count;
                    snapshot-count: root.overview_snapshot_count;
                    last-snapshot-ts: root.overview_last_snapshot;
                    show-onboarding: root.show_onboarding;

                    open-bootloader-page => { root.active_tab = 2; }
                    open-secure-boot-page => { root.active_tab = 3; }
                    open-snapshots-page => { root.active_tab = 4; }
                    start-with-boot-entries => {
                        root.show_onboarding = false;
                        root.active_tab = 1;
                        root.never_show_onboarding();
                    }
                    learn-more => { root.learn_more(); }
                    never-show-onboarding => {
                        root.show_onboarding = false;
                        root.never_show_onboarding();
                    }
                }

                if root.active_tab == 1 : BootEntriesPage {
                    entries <=> root.entries;
                    show-loading: root.show_loading;
                    save-entry(k, v) => { root.save_entry(k, v); }
                }

                if root.active_tab == 2 : BootloaderPage {
                    active-backend: root.active_backend;
                }

                if root.active_tab == 3 : SecureBootPage {
                    active-backend: root.active_backend;
                    secure-boot-status: root.secure_boot_status;
                    mok-status: root.mok_status;
                    show-loading: root.show_loading;
                    backup-nvram => { root.backup_nvram(); }
                    enroll-mok => { root.enroll_mok(); }
                }

                if root.active_tab == 4 : SnapshotsPage {
                    snapshots: root.snapshot_rows;
                    disk-pressure: root.snapshots_disk_pressure;
                    disk-usage-text: root.snapshots_disk_usage;
                    restore-clicked(id) => { root.restore_snapshot(id); }
                    adjust-retention => { root.active_tab = 6; }
                    prune-now => { /* PR 7 wires to daemon snapshot::reap */ }
                    open-recovery-viewer => { root.open_recovery_viewer(); }
                    open-audit-log(jid) => { root.open_audit_log(jid); }
                }

                if root.active_tab == 5 : LogsPage {
                    rows: root.log_rows;
                    only-failures <=> root.logs_only_failures;
                    only-mine <=> root.logs_only_mine;
                    time-window <=> root.logs_time_window;
                    toggle-filter(f) => { root.toggle_logs_filter(f); }
                    copy-row(jid) => { root.copy_log_row(jid); }
                    save-as => { root.save_logs_as(); }
                }

                if root.active_tab == 6 : SettingsPage {
                    retention-preset <=> root.settings_retention_preset;
                    auto-dismiss-successes <=> root.settings_auto_dismiss;
                    high-contrast-override <=> root.settings_high_contrast;
                    reduced-motion-override <=> root.settings_reduced_motion;
                    strict-mode-allowed: root.settings_strict_mode_allowed;
                }

                // Off-sidebar legacy route: Strict Mode (Q4 verdict will fold
                // this into Secure Boot page in PR 7).
                if root.active_tab == 7 : SecurityLabPage {
                    show-loading: root.show_loading;
                    paranoia-confirmed <=> root.paranoia_confirmed;
                    generate-paranoia => { root.generate_paranoia(); }
                    merge-paranoia => { root.merge_paranoia(); }
                }
            }
        }
    }

    // ── Confirmation Sheet (overlays everything when active) ────────────────
    ConfirmationSheet {
        visible-prop: root.show_confirmation;
        verb-label: root.confirmation_verb;
        restated-target: root.confirmation_target;
        required-confirm-text: root.confirmation_required_text;
        typed-text <=> root.confirmation_typed_text;
        diff: root.confirmation_diff;
        preflight: root.confirmation_preflight;
        preflight-all-pass: root.confirmation_preflight_all_pass;
        command-cli: root.confirmation_command_cli;
        snapshot-id: root.confirmation_snapshot_id;
        cancel => {
            root.show_confirmation = false;
            root.confirmation_typed_text = "";
        }
        confirm => {
            root.show_confirmation = false;
            root.confirmation_confirmed();
            root.confirmation_typed_text = "";
        }
        copy-command => { root.copy_command(root.confirmation_command_cli); }
    }

    // ── RecoveryViewer overlay ──────────────────────────────────────────────
    RecoveryViewer {
        visible-prop: root.show_recovery_viewer;
        markdown-source: root.recovery_markdown;
        close => { root.show_recovery_viewer = false; }
    }

    // ── Toast (floats above everything except overlays) ─────────────────────
    ToastNotification {
        x: (parent.width - self.width) / 2;
        y: root.show_toast ? parent.height - self.height - Tokens.space-xl : parent.height + 10px;
        message: root.toast_message;
        toast_type: root.toast_type;
        is_visible: root.show_toast;
        dismiss => { root.dismiss_toast(); }
    }
}
